# Database
DUCKDB_PATH=./fitness.duckdb

# Garmin Connect (garth)
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=yourpassword
GARTH_HOME=~/.garth           # token cache directory

# Strava OAuth2
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_REFRESH_TOKEN=your_refresh_token  # obtained once via OAuth flow

# Google Fit OAuth2
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token  # scope: fitness.activity.read + sleep + body

# Suunto (Cloud Partner API)
SUUNTO_CLIENT_ID=your_client_id
SUUNTO_CLIENT_SECRET=your_client_secret
SUUNTO_REFRESH_TOKEN=your_refresh_token
SUUNTO_SUBSCRIPTION_KEY=your_ocp_apim_subscription_key
